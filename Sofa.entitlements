<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Notarization requires the hardened runtime, which by default blocks
	     sending Apple Events to other apps. Sofa's whole sync mechanism is
	     AppleScript/JavaScript-in-browser control of QuickTime, VLC, Safari,
	     Chrome, Music, Spotify and TV — without this, every osascript call
	     would fail on a notarized build. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>

	<!-- Team-ID–scoped access to the modern "data protection" keychain (the same
	     one iOS uses). It lets Sofa read its own stored device credential keyed
	     to the Developer ID Team (SX87SFWP3N) instead of to a specific signing
	     certificate, so macOS never shows the "enter your login keychain
	     password" prompt — not on a fresh install, and not after a future
	     certificate renewal. Required for kSecUseDataProtectionKeychain on a
	     Developer ID (non-sandboxed) app. See SocialService.KeychainCredential. -->
	<key>com.apple.application-identifier</key>
	<string>SX87SFWP3N.com.pablo.sofa.native</string>
</dict>
</plist>
