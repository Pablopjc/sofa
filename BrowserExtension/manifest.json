{
  "manifest_version": 3,
  "name": "Sofa Theater",
  "version": "0.1.32",
  "description": "A clean Theater layout for Sofa watch parties. No chat, overlays, or page controls.",
  "content_scripts": [
    {
      "matches": [
        "https://*.netflix.com/*",
        "https://netflix.com/*",
        "https://*.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}